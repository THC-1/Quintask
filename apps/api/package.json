{
  "name": "@quintask/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build -w @quintask/shared && node --env-file=../../.env ../../node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../../.env dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "node --env-file=../../.env ../../node_modules/prisma/build/index.js generate",
    "db:migrate": "node --env-file=../../.env ../../node_modules/prisma/build/index.js migrate dev",
    "db:seed": "node --env-file=../../.env ../../node_modules/tsx/dist/cli.mjs prisma/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@prisma/client": "^6.8.2",
    "@quintask/shared": "0.1.0",
    "bcryptjs": "^3.0.2",
    "hono": "^4.7.10",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.18",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
